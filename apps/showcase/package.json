{
  "name": "@rnr/showcase",
  "main": "index.js",
  "version": "0.0.3",
  "scripts": {
    "start": "ENV=development expo start --clear",
    "device:ios": "ENV=development expo run:ios --device",
    "device:ios:prod": "expo run:ios --device",
    "ios": "ENV=development expo run:ios",
    "ios:prod": "expo run:ios",
    "device:android": "ENV=development expo run:android --device",
    "device:android:prod": "expo run:android --device",
    "android": "ENV=development expo run:android",
    "android:prod": "expo run:android",
    "prebuild": "ENV=development expo prebuild --clean",
    "prebuild:ios": "ENV=development expo prebuild --platform ios --clean",
    "prebuild:android": "ENV=development expo prebuild --platform android --clean",
    "prebuild:prod": "expo prebuild --clean",
    "testflight": "eas build -p ios --submit",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production --auto-submit",
    "update:ios": "eas update --platform ios",
    "build:web": "npx expo export -p web",
    "serve:web": "npx serve dist --single",
    "clean": "rm -rf .expo node_modules",
    "postinstall": "npx tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.0",
    "@react-navigation/native": "^7.0.0",
    "@rn-primitives/aspect-ratio": "1.4.0-beta.2",
    "@rn-primitives/collapsible": "1.4.0-beta.2",
    "@rn-primitives/label": "1.4.0-beta.2",
    "@rn-primitives/portal": "1.4.0-beta.2",
    "@rn-primitives/slider": "1.4.0-beta.2",
    "@rn-primitives/toast": "1.4.0-beta.2",
    "@rn-primitives/toolbar": "1.4.0-beta.2",
    "@rnr/registry": "workspace:*",
    "@shopify/flash-list": "2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^55.0.6",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.13",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.1",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.14",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.3"
  },
  "private": true
}
